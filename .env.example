# Dimentos AI Studio OS - Environment Variables Example
# Copy to .env and fill in your values
# DO NOT PUT REAL SECRETS IN THIS FILE

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Database
POSTGRES_USER=dimentos
POSTGRES_PASSWORD=
POSTGRES_DB=dimentos_ai
DATABASE_URL=postgresql+asyncpg://dimentos:PASSWORD@postgres:5432/dimentos_ai

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_SECRET_KEY=  # generate with: openssl rand -hex 32
API_HOST=0.0.0.0
API_PORT=8000

# GitHub
GITHUB_USER=
GITHUB_EMAIL=
GITHUB_TOKEN=  # Get from github.com/settings/tokens

# AI Providers (fill manually)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=

# Domain
DOMAIN=
APP_URL=
API_URL=

# Logging
LOG_LEVEL=INFO
